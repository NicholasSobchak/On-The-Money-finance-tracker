# On The Money - Production Environment Variables
# Copy to .env on your VPS and fill in real values

# Database
DB_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# Plaid (get from https://dashboard.plaid.com/team/keys)
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=production
PLAID_REDIRECT_URI=https://onthemoney.site/api/plaid/oauth-callback

# Finnhub (get from https://finnhub.io/register)
FINNHUB_API_KEY=your_finnhub_api_key

# API Key (generate with: openssl rand -hex 32)
API_KEY=CHANGE_ME_TO_A_RANDOM_KEY
